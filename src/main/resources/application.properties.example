# App
spring.application.name=healthbridge

# PostgreSQL Database
spring.datasource.url=jdbc:postgresql://localhost:5432/healthbridge_db
spring.datasource.username=your_postgres_username
spring.datasource.password=your_postgres_password
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true

# File upload
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# JWT
jwt.secret=your_jwt_secret_at_least_32_characters_long
jwt.expiration=86400000

# LLM API (Groq - free at https://console.groq.com)
llm.api.key=your_groq_api_key_here
llm.api.url=https://api.groq.com/openai/v1/chat/completions